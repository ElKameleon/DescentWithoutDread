; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[animation]

compatibility/default_parent_skeleton_in_mesh_instance_3d=true

[application]

config/name="Idols of Ash"
config/version="1.30"
run/main_scene="uid://syd4oyyq4s5r"
config/features=PackedStringArray("4.6", "Forward Plus")
run/max_fps=120
config/icon="res://icon.svg"

[audio]

buses/default_bus_layout="uid://deqfcgjnl6003"
general/3d_panning_strength=1.01

[autoload]

ModLoaderStore="*uid://b1okosx4p1jsf"
ModLoader="*uid://bx0ec1vffwoqe"
OnscreenMessage="*res://scripts/onscreen_messages.gd"
Dialogic="*res://addons/dialogic/Core/DialogicGameHandler.gd"
Game="*res://scripts/game.gd"
GameSettings="*res://scripts/game_settings.gd"
SceneLoader="*res://scripts/scene_loader.gd"
ControllerIcons="*res://addons/controller_icons/ControllerIcons.gd"
PlayerData="*uid://b0p7hwu3pawws"
InputMappingSystem="*uid://cjyd5e8njohyk"
SandboxDataManager="*res://scripts/sandbox_data_manager.gd"
PlayerHistoryManager="*res://scripts/player_history_manager.gd"

[debug]

file_logging/enable_file_logging=true

[debug_draw_3d]

settings/addon_root_folder="res://addons/debug_draw_3d"

[dialogic]

directories/dch_directory={
"Narrator": "res://Dialogue/Narrator.dch"
}
directories/dtl_directory={
"Lore_1": "res://Dialogue/Lore_1.dtl",
"Lore_2": "res://Dialogue/Lore_2.dtl",
"Lore_3": "res://Dialogue/Lore_3.dtl",
"Lore_4": "res://Dialogue/Lore_4.dtl",
"Lore_5": "res://Dialogue/Lore_5.dtl",
"Tent": "res://Dialogue/Tent.dtl",
"TestTimeline": "res://Dialogue/TestTimeline.dtl",
"lore_point_test": "res://Dialogue/lore_point_test.dtl"
}
layout/style_list=["res://Dialogue/Style.tres"]
layout/default_style="res://Dialogue/Style.tres"
extensions_folder="res://addons/dialogic_additions"
text/letter_speed=0.04
text/initial_text_reveal_skippable=true
text/text_reveal_skip_delay=0.1
text/advance_delay=0.1
text/autoadvance_per_character_delay=0.1
text/autoadvance_ignored_characters_enabled=true
audio/max_channels=4.0
animations/join_default_length=0.5
animations/join_default_wait=true
animations/leave_default_length=0.5
animations/leave_default_wait=true
animations/cross_fade_default_length=0.5
choices/autofocus_first=true
choices/delay=0.2
choices/reveal_delay=0
choices/reveal_by_input=false
save/autosave_delay=60.0
save/encryption_on_exports_only=true
text/autopauses={}
glossary/default_case_sensitive=true
variables={}
text/input_action="ioa_dialogic_default_action"
timer/process_in_physics=false
audio/type_sound_bus="MainBus"
event_default_overrides={
"Music": {
"audio_bus": "MainBus"
},
"Sound": {
"audio_bus": "MainBus"
}
}

[display]

window/size/viewport_width=640
window/size/viewport_height=360
window/size/mode=2
window/stretch/mode="viewport"
window/stretch/aspect="keep_height"
window/vsync/vsync_mode=0

[dotnet]

project/assembly_name="grapplegame"

[editor_overrides]

text_editor/behavior/indent/type=1

[editor_plugins]

enabled=PackedStringArray("res://addons/controller_icons/plugin.cfg", "res://addons/dialogic/plugin.cfg", "res://addons/dwd_release/plugin.cfg", "res://addons/mod_loader/_export_plugin/plugin.cfg")

[file_customization]

folder_colors={
"res://mods-unpacked/": "red"
}

[importer_defaults]

texture={
"compress/channel_pack": 0,
"compress/hdr_compression": 1,
"compress/high_quality": false,
"compress/lossy_quality": 0.7,
"compress/mode": 0,
"compress/normal_map": 0,
"detect_3d/compress_to": 1,
"mipmaps/generate": false,
"mipmaps/limit": -1,
"process/fix_alpha_border": true,
"process/hdr_as_srgb": false,
"process/hdr_clamp_exposure": false,
"process/normal_map_invert_y": false,
"process/premult_alpha": false,
"process/size_limit": 256,
"roughness/mode": 0,
"roughness/src_normal": ""
}

